# =============================================
# JR Acessórios — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus dados reais
# =============================================

# Configurações do Supabase (obrigatório para autenticação e banco de dados)
# Obtenha em: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Links de Redes Sociais (obrigatório para o rodapé e contato)
# Exemplo: https://www.instagram.com/seu_perfil
VITE_INSTAGRAM_URL=
# Exemplo: 5511999999999 (Código do país + DDD + Número)
VITE_WHATSAPP_NUMBER=

# Mercado Pago — chave pública (obrigatório para pagamentos via Pix/Boleto)
# Obtenha em: Painel Mercado Pago > Suas integrações > Credenciais de produção
VITE_MP_PUBLIC_KEY=

# Stripe — chave pública (obrigatório para pagamentos com cartão de crédito)
# Obtenha em: Stripe Dashboard > Developers > API keys (Publishable key)
VITE_STRIPE_PUBLISHABLE_KEY=

# Google Analytics 4 (opcional, mas recomendado para produção)
# Obtenha em: Google Analytics > Admin > Fluxos de dados > ID de medição (formato: G-XXXXXXXXXX)
VITE_GA4_ID=

# =============================================
# Secrets do Supabase (configurar em: Supabase > Project Settings > Edge Functions > Secrets)
# NÃO prefixar com VITE_ — estas vars ficam apenas no servidor
# =============================================
MERCADOPAGO_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
OPENAI_API_KEY=
ALLOWED_ORIGIN=https://SEU_DOMINIO_AQUI
