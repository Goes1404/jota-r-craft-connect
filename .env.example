# =============================================
# JR Acessórios — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus dados reais
# =============================================

# Configurações do Supabase (obrigatório para autenticação e banco de dados)
# Obtenha em: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Links de Redes Sociais (obrigatório para o rodapé e contato)
# Exemplo: https://www.instagram.com/seu_perfil
VITE_INSTAGRAM_URL=
# Exemplo: 5511999999999 (Código do país + DDD + Número)
VITE_WHATSAPP_NUMBER=

# Mercado Pago — chave pública (obrigatório para pagamentos via Pix/Boleto)
# Obtenha em: Painel Mercado Pago > Suas integrações > Credenciais de produção
VITE_MP_PUBLIC_KEY=

# Stripe — chave pública (obrigatório para pagamentos com cartão de crédito)
# Obtenha em: Stripe Dashboard > Developers > API keys (Publishable key)
VITE_STRIPE_PUBLISHABLE_KEY=

# Google Analytics 4 (opcional, mas recomendado para produção)
# Obtenha em: Google Analytics > Admin > Fluxos de dados > ID de medição (formato: G-XXXXXXXXXX)
VITE_GA4_ID=

# =============================================
# Secrets do Supabase (configurar em: Supabase > Project Settings > Edge Functions > Secrets)
# NÃO prefixar com VITE_ — estas vars ficam apenas no servidor
# =============================================
MERCADOPAGO_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
OPENAI_API_KEY=
ALLOWED_ORIGIN=https://SEU_DOMINIO_AQUI

# ── Split automático do CARTÃO (Stripe Connect) — opcional ───────────────────
# Sem estas duas, o cartão NÃO divide sozinho (100% vai para uma conta só).
# STRIPE_PLATFORM_SECRET_KEY = chave secreta da SUA conta de plataforma (dev)
# STRIPE_MERCHANT_ACCOUNT_ID = id da conta conectada do lojista (acct_...)
STRIPE_PLATFORM_SECRET_KEY=
STRIPE_MERCHANT_ACCOUNT_ID=

# ── Split automático do PIX (MercadoPago Marketplace) — opcional ─────────────
# Crie um app em modo Marketplace no painel do MercadoPago (sua conta de dev).
# MP_CLIENT_ID / MP_CLIENT_SECRET = credenciais do app marketplace
# MP_REDIRECT_URI = https://<PROJECT_REF>.supabase.co/functions/v1/mp-oauth-callback
# APP_BASE_URL    = URL do site para onde o callback redireciona (ex: https://jracessorios.com)
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_REDIRECT_URI=
APP_BASE_URL=

# E-mail que recebe a notificação de novos pedidos
ADMIN_EMAIL=
